# Backend env config
# Copy this file to .env and adjust values.

MODEL_PATH=app/data/model/fruit/best.pt
FRUIT_MODEL_PATH=app/data/model/fruit/best.pt
VEGETABLE_MODEL_PATH=app/data/model/vegetable/best.pt
CONF_THRES=0.25
IOU_THRES=0.45
# Example: apple,orange,banana,pear,grape,mandarin orange,orange/orange fruit
DETECTION_CLASS_ALLOWLIST=
DEVICE=cpu
SAVE_EMPTY_RESULTS=false
RECORD_RETENTION_LIMIT=50
VIDEO_SAMPLE_INTERVAL=10
TRACKER_MAX_AGE=30
TRACKER_N_INIT=2
TRACKER_MAX_IOU_DISTANCE=0.7
TRACKER_MAX_COSINE_DISTANCE=0.3
TRACKER_NN_BUDGET=50
TRACKER_MAX_TIME_SINCE_UPDATE=5
TRACKER_TRAJECTORY_LEN=64
TRACKER_RENDER_STALE_FRAMES=12
TRACKER_FALLBACK_IOU=0.3
CAMERA_TRACKER_SESSION_TTL_SEC=120
CAMERA_IMGSZ=416
CAMERA_CONF_THRES=0.35
CAMERA_IOU_THRES=0.45
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FRAME_SKIP=2
CAMERA_DEVICE=auto
CAMERA_HALF=auto
CAMERA_JPEG_QUALITY=75
CAMERA_TRACKER_MAX_AGE=15
CAMERA_TRACKER_N_INIT=2
CAMERA_TRACKER_MAX_COSINE_DISTANCE=0.3
CAMERA_TRACKER_NN_BUDGET=50
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
