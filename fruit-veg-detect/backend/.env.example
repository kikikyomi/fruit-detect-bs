CAMERA_DEBUG=false
CAMERA_SAVE_EVERY_FRAME=false
CAMERA_USE_DEEPSORT=true
CAMERA_DEVICE=auto
CAMERA_HALF=auto
CAMERA_JPEG_QUALITY=75
CAMERA_TRACKER_MAX_AGE=80
CAMERA_TRACKER_N_INIT=2
CAMERA_TRACKER_MAX_COSINE_DISTANCE=0.5
CAMERA_TRACKER_NN_BUDGET=150
VIDEO_IMGSZ=512
VIDEO_CONF_THRES=0.30
VIDEO_IOU_THRES=0.45
VIDEO_FRAME_SKIP=1
VIDEO_OUTPUT_WIDTH=1280
