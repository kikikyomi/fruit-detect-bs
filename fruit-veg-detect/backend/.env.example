# Backend env config
# Copy this file to .env and adjust values.

MODEL_PATH=app/data/model/fruit/best.pt
FRUIT_MODEL_PATH=app/data/model/fruit/best.pt
VEGETABLE_MODEL_PATH=app/data/model/vegetable/best.pt
CONF_THRES=0.25
IOU_THRES=0.45
# Example: apple,orange,banana,pear,grape,mandarin orange,orange/orange fruit
DETECTION_CLASS_ALLOWLIST=
DEVICE=cpu
SAVE_EMPTY_RESULTS=false
RECORD_RETENTION_LIMIT=50
VIDEO_SAMPLE_INTERVAL=10
TRACKER_MAX_AGE=30
TRACKER_N_INIT=2
TRACKER_MAX_IOU_DISTANCE=0.7
TRACKER_MAX_TIME_SINCE_UPDATE=5
TRACKER_TRAJECTORY_LEN=64
TRACKER_RENDER_STALE_FRAMES=12
TRACKER_FALLBACK_IOU=0.3
CAMERA_TRACKER_SESSION_TTL_SEC=120
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
