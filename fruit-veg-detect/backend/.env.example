TRACKER_APPEARANCE_MAX_CENTER_DISTANCE_RATIO=2.5
TRACKER_APPEARANCE_COLOR_WEIGHT=0.55
TRACKER_APPEARANCE_TEXTURE_WEIGHT=0.30
TRACKER_APPEARANCE_POSITION_WEIGHT=0.15
CAMERA_TRACKER_SESSION_TTL_SEC=120
